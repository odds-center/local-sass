{
  "name": "local-sass",
  "version": "0.2.0",
  "description": "HR SaaS — multi-tenant leave management",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev:server": "tsc -p tsconfig.electron.json && node dist-electron/main/standalone.js",
    "build:icon": "node scripts/build-icon.js",
    "build": "node scripts/build-icon.js && vite build && tsc -p tsconfig.electron.json && electron-builder --config electron-builder.config.cjs",
    "build:mac": "node scripts/build-icon.js && vite build && tsc -p tsconfig.electron.json && electron-builder --mac --config electron-builder.config.cjs",
    "build:win": "vite build && tsc -p tsconfig.electron.json && electron-builder --win --config electron-builder.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.11.6",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bignumber.js": "^10.0.2",
    "bonjour-service": "^1.3.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^140.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.0.1",
    "morgan": "^1.10.1",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.5",
    "react-router-dom": "^6.23.1",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "typeorm": "^0.3.28",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  }
}
